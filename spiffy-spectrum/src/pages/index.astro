---
// src/pages/index.astro
---
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>唐靖軒 · 林子瑜 婚禮邀請</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400;1,600&family=Noto+Serif+TC:wght@300;400;600;700&display=swap" rel="stylesheet">
  
  <style>
    :root{
      --tide-deep: #1E444F;
      --tide-mid: #35827D;
      --dusk-gold: #C59B47;
      --gold-light: #E8D08C;
      --ink-navy: #0B191F;
      --sand: #F3EEE3;
      --lace: #FFFDF8;
      --ink-soft: #5b5d5c;
    }
    *{ box-sizing:border-box; margin:0; padding:0; }
    html{ scroll-behavior:smooth; }
    
    body{
      background: #EBE5D9; 
      color: var(--ink-navy);
      font-family: 'Noto Serif TC', serif;
      font-weight: 300;
      letter-spacing: 0.03em;
      overflow-x: hidden;
    }
    .serif-en{ font-family: 'Cormorant Garamond', serif; }

    /* ============ 加寬版的精緻雙層金框 (大氣不狹窄) ============ */
    .page-wrapper {
      max-width: 920px; 
      margin: 3rem auto;
      padding: 1.5rem;
      border: 2px solid var(--dusk-gold);
      position: relative;
      background-color: var(--sand);
      box-shadow: 0 20px 50px rgba(0,0,0,0.1);
    }
    .page-wrapper::before {
      content: "";
      position: absolute;
      inset: 8px;
      border: 1px dashed rgba(197, 155, 71, 0.5);
      pointer-events: none;
      z-index: 20;
    }
    .page-wrapper::after {
      content: "◇ ❦ ◇ ❦ ◇ ❦ ◇ ❦ ◇ ❦ ◇ ❦ ◇ ❦ ◇";
      display: block;
      text-align: center;
      color: var(--dusk-gold);
      letter-spacing: 0.5em;
      font-size: 0.8rem;
      margin-top: 2rem;
      opacity: 0.7;
    }

    /* HERO 主視覺 */
    .hero{
      position: relative; 
      width: 100%; 
      min-height: 85vh; 
      background: var(--tide-deep);
      display: flex; flex-direction: column; justify-content: center; align-items: center;
      overflow: hidden;
      border-radius: 4px;
    }
    .hero-bg-slide {
      position: absolute; inset: 0; z-index: 0;
      background-size: cover; background-position: center bottom;
      opacity: 0; transition: opacity 1.5s ease-in-out;
    }
    .hero-bg-slide.active { opacity: 0.5; }
    .hero-gradient {
      position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(180deg, rgba(11,25,31,0.2) 0%, rgba(11,25,31,0.65) 100%);
    }
    .hero-topbar{
      position: absolute; top: 2.5rem; left: 0; right: 0; z-index: 3;
      text-align: center; color: #fff; font-size: 1.05rem; letter-spacing: 0.1em;
    }
    .hero-content { 
      position: relative; 
      z-index: 3; 
      text-align: center; 
      width: 100%; 
      padding: 0 1rem; 
      margin-top: 2rem;
    }

    /* ============ 金色呼吸心 ============ */
    .hero-elegant-heart {
      margin: 0 auto;
      z-index: 4;
      font-size: 2.6rem;
      line-height: 1;
      background: linear-gradient(135deg, #E8D08C 0%, #C59B47 50%, #9A7326 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      filter: drop-shadow(0 0 15px rgba(232, 208, 140, 0.6));
      animation: elegantPulse 2.8s ease-in-out infinite;
    }
    @keyframes elegantPulse {
      0%, 100% { transform: scale(1); opacity: 0.85; }
      50% { transform: scale(1.12); opacity: 1; }
    }

    /* 乾淨無壓紋的純白卡片 */
    .clean-card {
      background: var(--lace);
      border-radius: 6px;
      border: 1px solid rgba(197, 155, 71, 0.3);
      box-shadow: 0 15px 35px -10px rgba(11,25,31,0.15);
      position: relative;
      z-index: 10;
    }

    /* 婚宴資訊卡片 */
    .hero-infobar{
      width: 90%; max-width: 600px;
      margin: -3.5rem auto 2rem; 
      padding: 2.2rem 1.5rem; 
      text-align: center;
    }
    .hero-infobar .date{ font-size: 1.2rem; font-weight: 600; color: var(--tide-deep); margin-bottom: 0.6rem; letter-spacing: 0.05em; }
    .hero-infobar .place{ font-size: 0.95rem; color: var(--ink-soft); }
    .date-sub{
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--dusk-gold);
    margin-bottom: 0.3rem;
}
    /* 藝術感問候區塊 */
    section.greeting-section { padding: 2rem 1.5rem 3rem; text-align: center; max-width: 650px; margin: 0 auto; }
    .greeting-box { padding: 3.5rem 2rem; }
    .greeting{ 
      font-family: 'Noto Serif TC', serif;
      font-size: 1.8rem; 
      font-weight: 600;
      color: var(--tide-deep); 
      margin-bottom: 0.8rem; 
      letter-spacing: 0.15em;
    }
    .highlight-gold {
      background: linear-gradient(135deg, #E8D08C 0%, #C59B47 50%, #9A7326 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      font-weight: 700;
      text-shadow: 0 0 15px rgba(197, 155, 71, 0.3);
    }
    .greeting-sub{ font-size: 1rem; color: var(--ink-soft); line-height: 2.2; letter-spacing: 0.08em; }

    /* GAYA 飯店沉浸式背景區塊 */
    .venue-immersive {
      position: relative; width: 100%; padding: 6rem 1.5rem; color: #fff; overflow: hidden; margin: 2rem 0; border-radius: 4px;
    }
    .venue-bg {
      position: absolute; inset: 0; z-index: 0;
      background-size: cover; background-position: center; opacity: 0; transition: opacity 1.5s ease-in-out;
    }
    .venue-bg.active { opacity: 0.48; }
    .venue-overlay { position: absolute; inset: 0; z-index: 1; background: rgba(11, 25, 31, 0.78); }
    .venue-content { position: relative; z-index: 2; max-width: 500px; margin: 0 auto; text-align: center; }
    .section-eyebrow{ font-size: 0.85rem; letter-spacing: 0.3em; color: var(--gold-light); text-transform: uppercase; margin-bottom: 1rem; font-family: 'Cormorant Garamond', serif; }
    .venue-content h2 {
      color: #fff; font-size: 1.4rem; font-weight: 400; line-height: 1.8; margin-bottom: 1.5rem; letter-spacing: 0.08em;
    }
    .venue-desc { font-size: 1rem; line-height: 2.2; color: rgba(255, 255, 255, 0.85); margin-bottom: 2rem; }
    .venue-name-card {
      display: inline-block; border: 1px solid rgba(232, 208, 140, 0.5);
      padding: 0.8rem 2rem; border-radius: 999px; font-size: 0.9rem; letter-spacing: 0.1em; color: var(--gold-light); background: rgba(0,0,0,0.3); backdrop-filter: blur(4px);
    }

    /* RSVP 表單樣式 */
    section.rsvp-section { padding: 3rem 1.5rem; max-width: 650px; margin: 0 auto; }
    .rsvp-card{ padding: 3rem 2.5rem; text-align: left; }
    .field{ margin-bottom: 1.8rem; }
    .field label{ display: block; font-size: 0.85rem; letter-spacing: 0.15em; color: var(--tide-deep); margin-bottom: 0.8rem; font-weight: 600; }
    .field input[type="text"]{
      width: 100%; border: none; border-bottom: 1.5px solid rgba(53,130,125,0.3);
      background: transparent; padding: 0.6rem 0.2rem; font-family: 'Noto Serif TC', serif;
      font-size: 1.05rem; color: var(--ink-navy); outline: none; transition: 0.3s;
    }
    .field input:focus{ border-color: var(--dusk-gold); }
    .counter-row{ display: flex; gap: 1.5rem; }
    .counter-field{ flex: 1; }
    .stepper{ display: flex; align-items: center; justify-content: space-between; border: 1.5px solid rgba(53,130,125,0.3); border-radius: 6px; padding: 0.5rem 0.8rem; background: #fff; }
    .stepper button{ width: 28px; height: 28px; border: none; background: var(--sand); color: var(--tide-deep); font-size: 1.1rem; border-radius: 50%; cursor: pointer; line-height: 1; transition: 0.2s; }
    .stepper span{ font-size: 1.1rem; min-width: 24px; text-align: center; color: var(--tide-deep); font-weight: 600; }
    .veg-toggle{ display: flex; align-items: center; gap: 0.8rem; font-size: 1rem; color: var(--ink-navy); }
    .veg-toggle input{ width: 20px; height: 20px; accent-color: var(--tide-deep); cursor: pointer; }
    .btn-submit{
      width: 100%; margin-top: 1rem; padding: 1rem; border: none; border-radius: 999px;
      background: linear-gradient(135deg, var(--tide-deep), var(--tide-mid)); color: #fff;
      font-size: 1.1rem; letter-spacing: 0.1em; cursor: pointer;
      box-shadow: 0 6px 15px rgba(30,68,79,0.3);
      transition: all 0.3s;
    }
    .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 10px 20px rgba(30,68,79,0.4); }
    .btn-submit:disabled{ opacity: 0.6; pointer-events: none; }
    
    /* ============ 完美修復：優雅的中文字體與金色漸層「謝謝您」 ============ */
    .thank-you{ display: none; text-align: center; padding: 4rem 0.5rem; }
    .thank-you .big{ 
      font-family: 'Noto Serif TC', serif; 
      font-style: italic; 
      font-size: 1.8rem; 
      font-weight: 600;
      letter-spacing: 0.1em;
      background: linear-gradient(135deg, #E8D08C 0%, #C59B47 50%, #9A7326 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      margin-bottom: 1.2rem; 
    }
    .thank-you .sub{
      font-family: 'Noto Serif TC', serif;
      color: var(--ink-soft); 
      letter-spacing: 0.08em; 
      font-size: 1.1rem;
    }

    /* 頁尾 */
    .closing{ padding: 2rem 1.5rem 4rem; text-align: center; }
    .closing .names-sm{ font-family:'Cormorant Garamond', serif; font-style:italic; font-size:1.6rem; color:var(--dusk-gold); letter-spacing: 0.1em; }

    /* 滑動浮現特效 */
    .fade-up {
      opacity: 0;
      transform: translateY(30px);
      transition: opacity 1s ease-out, transform 1s ease-out;
    }
    .fade-up.visible {
      opacity: 1;
      transform: translateY(0);
    }
    /* ============ 手機版字級調整 ============ */
    @media (max-width: 480px) {
      .hero-topbar { font-size: 0.85rem; letter-spacing: 0.08em; }
      .hero-elegant-heart { font-size: 2rem; }

      .greeting { font-size: 1.35rem; letter-spacing: 0.06em; }
      .greeting-sub { font-size: 0.85rem; line-height: 1.8; }

      .hero-infobar .date { font-size: 1rem; }
      .hero-infobar .place { font-size: 0.8rem; }

      .section-eyebrow { font-size: 0.68rem; letter-spacing: 0.2em; }
      .venue-content h2 { font-size: 1.15rem; letter-spacing: 0.03em; line-height: 1.7; }
      .venue-desc { font-size: 0.85rem; line-height: 2; }
      .venue-name-card { font-size: 0.75rem; padding: 0.55rem 1.2rem; }

      .venue-immersive { padding: 4rem 1.2rem; }
      .greeting-box { padding: 2rem 1.2rem; }

      .closing .msg { font-size: 1rem; }
      .closing .names-sm { font-size: 1.1rem; }
    }
  </style>
</head>
<body>

  <!-- 整個喜帖的大框框 -->
  <div class="page-wrapper">

    <!-- HERO 主視覺 -->
    <div class="hero">
      <div class="hero-bg-slide active" style="background-image: url('/images/07231.jpg');"></div>
      <div class="hero-bg-slide" style="background-image: url('/images/07232.jpg');"></div>
      <div class="hero-gradient"></div>

      <div class="hero-topbar">
        <span>唐靖軒 · 林子瑜</span>
      </div>

      <div class="hero-content">
        <!-- 完美的漸層金文字愛心 -->
        <div class="hero-elegant-heart">♥</div>
      </div>
    </div>

    <!-- 婚宴資訊卡片 -->
    <div class="hero-infobar clean-card fade-up">
      <div class="date">2026 年 11 月 22 日</div>
      <div class="date-sub serif-en">SUNDAY</div>
      <div class="date">18:30 開席</div>
      <div class="place">THE GAYA HOTEL · 10F KI-PA</div>
    </div>

    <!-- 問候區塊 -->
    <section class="greeting-section fade-up">
      <div class="greeting-box clean-card">
        <p class="greeting">
          <span class="highlight-gold">靖</span>好歲月, 都<span class="highlight-gold">瑜</span>你
        </p>
        <p class="greeting-sub">我們想，把接下來的日子都算在一起</p>
      </div>
    </section>

    <!-- GAYA 飯店沉浸式背景區塊 -->
    <div class="venue-immersive fade-up">
      <div class="venue-bg active" style="background-image: url('/images/S__20357193_0.jpg');"></div>
      <div class="venue-bg" style="background-image: url('/images/S__20357194_0.jpg');"></div>
      <div class="venue-bg" style="background-image: url('/images/S__20357195_0.jpg');"></div>
      <div class="venue-overlay"></div>

      <div class="venue-content">
        <p class="section-eyebrow">The Celebration</p>
        <h2>我們特地選在可眺望台東美景的<br>GAYA 飯店舉辦婚禮</h2>
        <p class="venue-desc">
          沒有繁瑣的儀式，只想邀請最重要的你<br>
          與我們一同分享這份喜悅與幸福。
        </p>
        <div class="venue-name-card">
          The GAYA Hotel 潮渡假酒店<br>
          10 樓 Ki-Pa 廳
        </div>
      </div>
    </div>

    <!-- RSVP 出席登記表單區塊 -->
    <section id="rsvp" class="rsvp-section fade-up">
      <div style="text-align: center; margin-bottom: 2.5rem;">
        <p class="section-eyebrow" style="color: var(--dusk-gold);">RSVP</p>
        <h2 style="font-size: 1.8rem; color: var(--tide-deep); letter-spacing: 0.1em;">出席登記</h2>
      </div>

      <div class="rsvp-card clean-card">
        <form id="rsvpForm" onsubmit="return false;">
          <div class="field">
            <label>姓名 / 稱謂 *</label>
            <input type="text" id="rsvpName" placeholder="請輸入您的姓名">
          </div>

          <div class="field">
            <label>出席人數</label>
            <div class="counter-row">
              <div class="counter-field">
                <div class="stepper">
                  <button type="button" onclick="stepCount('rsvpAdults',-1)">−</button>
                  <span id="rsvpAdults">1</span>
                  <button type="button" onclick="stepCount('rsvpAdults',1)">+</button>
                </div>
                <div style="text-align:center;font-size:0.8rem;color:var(--ink-soft);margin-top:0.5rem;">大人</div>
              </div>
              <div class="counter-field">
                <div class="stepper">
                  <button type="button" onclick="stepCount('rsvpKids',-1)">−</button>
                  <span id="rsvpKids">0</span>
                  <button type="button" onclick="stepCount('rsvpKids',1)">+</button>
                </div>
                <div style="text-align:center;font-size:0.8rem;color:var(--ink-soft);margin-top:0.5rem;">小孩</div>
              </div>
            </div>
          </div>

          <div class="field">
            <label>飲食需求</label>
            <div class="veg-toggle">
              <input type="checkbox" id="rsvpVegCheck" onchange="toggleVeg()">
              <span>需要素食</span>
            </div>
            <div class="counter-row" id="vegCountRow" style="display:none; margin-top:1.2rem;">
              <div class="counter-field">
                <div class="stepper">
                  <button type="button" onclick="stepCount('rsvpVeg',-1)">−</button>
                  <span id="rsvpVeg">1</span>
                  <button type="button" onclick="stepCount('rsvpVeg',1)">+</button>
                </div>
                <div style="text-align:center;font-size:0.8rem;color:var(--ink-soft);margin-top:0.5rem;">素食人數</div>
              </div>
            </div>
          </div>

          <button class="btn-submit" id="rsvpSubmitBtn" onclick="submitRSVP()">確認送出</button>
        </form>

        <!-- 修正後的美麗中文字體與金色漸層 -->
        <div class="thank-you" id="thankYou">
          <p class="big">登記完成，謝謝您！</p>
          <p class="sub">我們 11 月 22 日台東見</p>
        </div>
      </div>
    </section>

    <!-- 結語 -->
    <section class="closing fade-up">
      <p class="names-sm">Jian Chung &amp; Tzu Yu</p>
    </section>

  </div> <!-- page-wrapper 結束 -->

  <!-- 互動腳本與動畫觀測器 -->
  <script>
    // 捲動浮現動畫觀測器
    document.addEventListener("DOMContentLoaded", function() {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            observer.unobserve(entry.target); 
          }
        });
      }, { threshold: 0.1 }); 

      document.querySelectorAll('.fade-up').forEach((el) => {
        observer.observe(el);
      });
    });

    // 背景輪播邏輯
    let currentHero = 0;
    const heroSlides = document.querySelectorAll('.hero-bg-slide');
    function changeHero() {
      if(heroSlides.length === 0) return;
      heroSlides[currentHero].classList.remove('active');
      currentHero = (currentHero + 1) % heroSlides.length;
      heroSlides[currentHero].classList.add('active');
    }
    setInterval(changeHero, 5000);

    let currentVenue = 0;
    const venueSlides = document.querySelectorAll('.venue-bg');
    function changeVenue() {
      if(venueSlides.length === 0) return;
      venueSlides[currentVenue].classList.remove('active');
      currentVenue = (currentVenue + 1) % venueSlides.length;
      venueSlides[currentVenue].classList.add('active');
    }
    setInterval(changeVenue, 6000);

    // 表單計數邏輯
    const counts = { rsvpAdults: 1, rsvpKids: 0, rsvpVeg: 1 };
    function stepCount(id, delta){
      const min = id === 'rsvpAdults' ? 1 : 0;
      counts[id] = Math.max(min, counts[id] + delta);
      document.getElementById(id).textContent = counts[id];
    }
    window.stepCount = stepCount;

    function toggleVeg(){
      const on = document.getElementById('rsvpVegCheck').checked;
      document.getElementById('vegCountRow').style.display = on ? 'flex' : 'none';
    }
    window.toggleVeg = toggleVeg;

    const SCRIPT_URL = 'https://script.google.com/macros/s/AKfycbxNkz5i5FCrU7cea06DDt7Nw3_LcHCWLeKNrABCd-8LpSt8lE3xmeDkRK1k3AtgMdPL8g/exec';

    async function submitRSVP(){
      const name = document.getElementById('rsvpName').value.trim();
      if(!name){ alert('請填寫姓名'); return; }

      const adults = counts.rsvpAdults;
      const kids = counts.rsvpKids;
      const vegOn = document.getElementById('rsvpVegCheck').checked;
      const veg = vegOn ? counts.rsvpVeg : 0;
      const note = '';

      const entry = { name, adults, kids, veg, note };

      const btn = document.getElementById('rsvpSubmitBtn');
      btn.disabled = true;
      btn.textContent = '送出中...';

      try{
        if(SCRIPT_URL){
          await fetch(SCRIPT_URL, {
            method: 'POST',
            mode: 'no-cors',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(entry)
          });
        }
        document.getElementById('rsvpForm').style.display = 'none';
        document.getElementById('thankYou').style.display = 'block';
      }catch(err){
        console.error(err);
        alert('送出時發生問題，請稍後再試一次。');
        btn.disabled = false;
        btn.textContent = '確認送出';
      }
    }
    window.submitRSVP = submitRSVP;
  </script>

</body>
</html>